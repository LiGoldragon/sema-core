# Sema Core — Field Classifications
# Maps every column of every sema-core relation to its scalar type.
# scalar: domain | bool | int | data
# target: Domain name (when scalar=domain), Measure formula (when scalar=int)
# unit: Unit domain name (when scalar=int)

# ═══════════════════════════════════════════════════════════════════════
# PILLAR 1 — Phase & Dignity (no phase/dignity columns — they ARE those)
# ═══════════════════════════════════════════════════════════════════════

?[relation, column, scalar, target, unit, description, phase, dignity] <- [
  ["Phase", "name", "data", "", "", "Phase variant name", "manifest", "eternal"],
  ["Phase", "glyph", "data", "", "", "Unicode glyph", "manifest", "eternal"],
  ["Phase", "in_world_hash", "bool", "", "", "Whether included in world hash", "manifest", "eternal"],
  ["Phase", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],

  ["Dignity", "name", "data", "", "", "Dignity variant name", "manifest", "eternal"],
  ["Dignity", "rank", "int", "L", "PositionUnit", "Trust ordering (0=highest)", "manifest", "eternal"],
  ["Dignity", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
]
:put field { relation, column => scalar, target, unit, description, phase, dignity }

# ═══════════════════════════════════════════════════════════════════════
# META — Domain, Functor, morphism
# ═══════════════════════════════════════════════════════════════════════

?[relation, column, scalar, target, unit, description, phase, dignity] <- [
  ["Domain", "name", "data", "", "", "Domain name", "manifest", "eternal"],
  ["Domain", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Domain", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Domain", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Functor", "name", "data", "", "", "Functor variant name", "manifest", "eternal"],
  ["Functor", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Functor", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Functor", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["morphism", "source", "domain", "Domain", "", "Source domain", "manifest", "eternal"],
  ["morphism", "target", "domain", "Domain", "", "Target domain", "manifest", "eternal"],
  ["morphism", "via", "data", "", "", "Morphism name/role", "manifest", "eternal"],
  ["morphism", "functor", "domain", "Functor", "", "Mapping type", "manifest", "eternal"],
  ["morphism", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["morphism", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["morphism", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],
]
:put field { relation, column => scalar, target, unit, description, phase, dignity }

