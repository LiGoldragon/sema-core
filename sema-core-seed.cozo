  ["Modality", "Three modalities — cardinal/fixed/mutable", "manifest", "eternal"],
  ["Sign", "Twelve zodiacal signs", "manifest", "eternal"],
  ["Planet", "Seven classical planets", "manifest", "eternal"],
  ["Measure", "Twelve measure formulae — Young Geometry of Meaning", "manifest", "eternal"],
  ["Dimension", "Twelve physics dimensions from Young", "manifest", "eternal"],
