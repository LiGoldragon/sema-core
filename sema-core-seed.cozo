  ["Aspect", "Geometric relationships between signs", "manifest", "eternal"],
  ["AspectNature", "Qualitative nature of geometric aspects", "manifest", "eternal"],
  ["Decan", "Thirty-six 10-degree divisions of the zodiac", "manifest", "eternal"],
  ["Rulership", "Planet-Sign dignity assignments", "manifest", "eternal"],
  ["DignityType", "Essential dignity classification — domicile/exaltation/detriment/fall", "manifest", "eternal"],
  ["Sect", "Diurnal-nocturnal binary division", "manifest", "eternal"],
