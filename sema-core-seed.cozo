?[name, description, phase, dignity] <- [
  ["deterministic", "Exactly one output for each input", "manifest", "eternal"],
  ["bijective", "One-to-one and onto — reversible", "manifest", "eternal"],
  ["tradition_dependent", "Mapping varies by tradition or context", "manifest", "eternal"],
]
:put Functor { name => description, phase, dignity }

